  3.8483201629673347`*^9, 3.8483201811061697`*^9}, {3.848320277718478*^9, 
  3.84832028265279*^9}, {3.8521235921106167`*^9, 3.8521235923157997`*^9}},
 CellLabel->
  "In[235]:=",ExpressionUUID->"55c845c8-9018-4881-837f-b7c1026b6f78"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   SqrtBox[
    RowBox[{"1", "-", 
     SubscriptBox["x", "1"], "-", 
     SubscriptBox["x", "2"], "-", 
     SubscriptBox["x", "3"]}]], ",", 
   SqrtBox[
    SubscriptBox["x", "3"]], ",", 
