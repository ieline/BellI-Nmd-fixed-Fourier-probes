Notebook[{

Cell[CellGroupData[{
Cell["Generalization of Bell inequalities", "Title",
 CellChangeTimes->{{3.848311408325556*^9, 
  3.84831142176492*^9}},ExpressionUUID->"73c4ff0f-48ce-4ae7-b54d-\
177f919d0676"],

Cell[TextData[{
 "In this notebook we want to generalize CHSH and CGLMP of the scenario \
(n,m,d), namely k\[Element][n] players, m possible settings ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "=", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["x", "1"], ",", "...", ",", 
       SubscriptBox["x", "n"]}], "}"}]}], ",", " ", 
    RowBox[{
     SubscriptBox["x", "k"], "\[Element]", 
     RowBox[{"[", "m", "]"}]}]}], TraditionalForm]],ExpressionUUID->
  "4ca91ae7-25e2-4f99-967c-b2e1d3add002"],
 " and  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"a", "=", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["a", "1"], ",", "...", ",", 
       SubscriptBox["a", "n"]}], "}"}]}], ",", " ", 
    RowBox[{
     SubscriptBox["a", "k"], "\[Element]", 
     RowBox[{"[", "d", "]"}]}]}], TraditionalForm]],ExpressionUUID->
  "2cfb9dfb-cba0-8f44-9ff4-d52b95ee0c8e"],
 " possible outcomes. The settings are defined in the tensor ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]", "=", 
    RowBox[{"{", 
     SubscriptBox["\[CurlyPhi]", 
      RowBox[{"k", ",", "x", ",", "a"}]], "}"}]}], TraditionalForm]],
  ExpressionUUID->"2d52db51-b8eb-46a0-a49b-8968a351e024"],
 " for the k-th player, x-th setting, a-th pin of the multiport.\nThe dream \
for the future is to generalize to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"n", ",", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["m", "1"], ",", "...", ",", 
       SubscriptBox["m", "n"]}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c6a6a299-1091-0749-8b3e-63c67f4b362d"],
 "},{",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "1"], ",", "...", ",", 
    SubscriptBox["d", "n"]}], TraditionalForm]],ExpressionUUID->
  "9ec6ba6d-6f22-ea49-b3e6-95fb255923c2"],
 "}) where each player has different settings and outcomes."
}], "Text",
 CellChangeTimes->{{3.8483114243280864`*^9, 3.8483114480134397`*^9}, {
  3.848311516470707*^9, 3.848311704476248*^9}, {3.8521950878916893`*^9, 
  3.852195129719346*^9}, {3.986356632853285*^9, 3.986356650726959*^9}, {
  3.9863566829834137`*^9, 3.9863567980952587`*^9}, {3.986357080750601*^9, 
  3.9863571219571915`*^9}},ExpressionUUID->"7fead732-29a6-45de-86bc-\
47bfb1dec60e"],

Cell["In this chapter I code the most general case (n,m,d).", "Text",
 CellChangeTimes->{{3.8521244628856072`*^9, 
  3.85212449878633*^9}},ExpressionUUID->"7b233b01-13da-4aa2-a23d-\
e07e7e3875ef"],

Cell[CellGroupData[{

Cell["Mathematical description", "Section",
 CellChangeTimes->{{3.8483143118041563`*^9, 3.8483143150699587`*^9}, {
  3.9665837271727395`*^9, 
  3.966583729029026*^9}},ExpressionUUID->"e359cc53-6848-4797-a728-\
1fdb912403a0"],

Cell["Let us consider a generic state", "Text",
 CellChangeTimes->{{3.848311756761025*^9, 3.8483118065197306`*^9}, {
   3.8483119324684114`*^9, 3.8483119405755177`*^9}, 
   3.9863571500057945`*^9},ExpressionUUID->"f846dc82-486d-4e27-924f-\
f83914177bf8"],

Cell[BoxData[
 RowBox[{
  TemplateBox[{"\[Psi]"},
   "Ket"], "=", 
  RowBox[{
   RowBox[{
    UnderscriptBox["\[Sum]", "b"], 
    RowBox[{
     SubscriptBox["c", "b"], 
     TemplateBox[{"b"},
      "Ket"]}]}], "=", 
   RowBox[{
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{
       SubscriptBox["b", "1"], "=", "1"}], "d"], "..."}], 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{
       SubscriptBox["b", "n"], "=", "1"}], "d"], 
     RowBox[{
      SubscriptBox["c", 
       RowBox[{
        SubscriptBox["b", "1"], ",", "...", ",", 
        SubscriptBox["b", "n"]}]], 
      TemplateBox[{
        RowBox[{
          SubscriptBox[
           SubscriptBox["b", "1"], 
           RowBox[{",", "...", ","}]], 
          SubscriptBox["b", "n"]}]},
       "Ket"]}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8483118426314697`*^9, 3.8483119133699074`*^9}, {
  3.848312139352589*^9, 3.8483121410998287`*^9}, {3.9615801358327103`*^9, 
  3.96158015417737*^9}, {3.966672959318564*^9, 3.966673002847757*^9}, {
  3.986356848787052*^9, 3.9863568618965645`*^9}, {3.9863571337550144`*^9, 
  3.986357176882799*^9}, {3.986358189157255*^9, 3.986358230175846*^9}, {
  3.9863603781131363`*^9, 3.986360386210884*^9}, {3.986982046381279*^9, 
  3.9869820623829594`*^9}},ExpressionUUID->"7bbcb954-1924-4ae0-8bd1-\
f859f191dc2d"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  SubscriptBox["a", "k"]], "Input",ExpressionUUID->
  "d7cc4137-7fb3-9841-a2fe-9bfc46db6d9b"],
 " represent the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "k"], "\[Element]", 
    RowBox[{"[", "d", "]"}]}], TraditionalForm]],ExpressionUUID->
  "613aaab1-66a5-466c-863d-96c6dd70a75e"],
 " . Each player apply a phase shift, then we have ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["x", "1"], ",", "...", ",", 
      SubscriptBox["x", "n"]}]}]}], TraditionalForm]],ExpressionUUID->
  "b280f8b5-a81d-4cc8-8cbc-1020395e92bf"],
 "}"
}], "Text",
 CellChangeTimes->{{3.8483119188303175`*^9, 3.848312102208604*^9}, {
  3.9666729880583515`*^9, 3.9666729945634108`*^9}, {3.986356873952511*^9, 
  3.986356913614666*^9}, {3.986357187986578*^9, 
  3.986357281216013*^9}},ExpressionUUID->"47cef3c4-4e52-44d4-8ee6-\
c2af136e886f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["\[CapitalPhi]", "x"], 
    TemplateBox[{"\[Psi]"},
     "Ket"]}], "=", 
   RowBox[{
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{
       SubscriptBox["b", "1"], "=", "1"}], "d"], "..."}], 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{
       SubscriptBox["b", "n"], "=", "1"}], "d"], 
     RowBox[{
      SubscriptBox["c", 
       RowBox[{
        SubscriptBox["b", "1"], ",", "...", ",", 
        SubscriptBox["b", "n"]}]], 
      TemplateBox[{
        RowBox[{
          SubscriptBox["\[CapitalPhi]", 
           SubscriptBox["x", "1"]], 
          SubscriptBox[
           SubscriptBox["b", "1"], 
           RowBox[{",", "...", ","}]], 
          SubscriptBox["\[CapitalPhi]", 
           SubscriptBox["x", "n"]], 
          SubscriptBox["b", "n"]}]},
       "Ket"]}]}]}]}], ",", "   ", 
  RowBox[{
   SubscriptBox["\[CapitalPhi]", 
    SubscriptBox["x", "k"]], "=", 
   RowBox[{"diag", 
    RowBox[{"{", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       SubscriptBox["\[ImaginaryI]\[CurlyPhi]", 
        RowBox[{"k", ",", 
         SubscriptBox["x", "k"], ",", "1"}]]], ",", "...", ",", 
      SuperscriptBox["\[ExponentialE]", 
       SubscriptBox["\[ImaginaryI]\[CurlyPhi]", 
        RowBox[{"k", ",", 
         SubscriptBox["x", "k"], ",", "d"}]]]}], "}"}], 
    " "}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8483118426314697`*^9, 3.8483119133699074`*^9}, {
  3.8483121195034585`*^9, 3.8483122747904587`*^9}, {3.8483123686448994`*^9, 
  3.848312369129283*^9}, {3.966673021128892*^9, 3.9666730309651427`*^9}, {
  3.986356917948412*^9, 3.9863569604752502`*^9}, {3.986357020152727*^9, 
  3.9863570202147274`*^9}, {3.986357291835308*^9, 3.9863573503269577`*^9}, {
  3.9863574172429256`*^9, 3.986357418980673*^9}, {3.986357667041565*^9, 
  3.986357750146612*^9}, {3.9863582826484127`*^9, 3.9863582908194447`*^9}, {
  3.9863583530675144`*^9, 3.986358421784828*^9}, {3.9864604360971355`*^9, 
  3.9864604510367928`*^9}, {3.9869820660161*^9, 
  3.9869820775785255`*^9}},ExpressionUUID->"ca1956b2-70b6-4790-8383-\
40730bbed9c5"],

Cell[TextData[{
 "Follows the common multiport ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["T", "ij"], "=", 
    RowBox[{
     RowBox[{"1", "/", 
      SqrtBox["d"]}], 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"i", "=", "1"}], "d"], 
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{"j", "=", "1"}], "d"], 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "\[ImaginaryI]"}], " ", 
         FractionBox[
          RowBox[{"2", "\[Pi]"}], "d"], 
         RowBox[{"(", 
          RowBox[{"i", "-", "1"}], ")"}], 
         RowBox[{"(", 
          RowBox[{"j", "-", "1"}], ")"}]}]]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"d6cb73ea-f29f-46f4-8a43-ac9e1029128d"],
 " "
}], "Text",
 CellChangeTimes->{{3.8483122873687325`*^9, 3.8483123661857443`*^9}, {
  3.986357398416527*^9, 
  3.9863574104970226`*^9}},ExpressionUUID->"b86432fc-59b7-4b09-aaa0-\
245a07a4810e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"T", " ", 
   SubscriptBox["\[CapitalPhi]", "x"], 
   TemplateBox[{"\[Psi]"},
    "Ket"]}], "=", 
  RowBox[{
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{
      SubscriptBox["b", "1"], "=", "1"}], "d"], "..."}], 
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{
      SubscriptBox["b", "n"], "=", "1"}], "d"], 
    RowBox[{
     SubscriptBox["c", 
      RowBox[{
       SubscriptBox["b", "1"], ",", "...", ",", 
       SubscriptBox["b", "n"]}]], 
     RowBox[{
      TemplateBox[{
        RowBox[{"T", " ", 
          SubscriptBox["\[CapitalPhi]", 
           SubscriptBox["x", "1"]], 
          SubscriptBox[
           SubscriptBox["b", "1"], 
           RowBox[{",", "...", ","}]], "T", " ", 
          SubscriptBox["\[CapitalPhi]", 
           SubscriptBox["x", "n"]], 
          SubscriptBox["b", "n"]}]},
       "Ket"], "."}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8483118426314697`*^9, 3.8483119133699074`*^9}, {
  3.8483121195034585`*^9, 3.8483122747904587`*^9}, {3.8483123686448994`*^9, 
  3.848312395714721*^9}, {3.9666730490234127`*^9, 3.966673057559784*^9}, {
  3.986356981942379*^9, 3.9863570080149746`*^9}, {3.986357421253746*^9, 
  3.98635744931168*^9}, {3.9863579647753105`*^9, 3.9863579724512634`*^9}, {
  3.9863584430756035`*^9, 3.986358456194542*^9}, {3.9863593050204277`*^9, 
  3.9863593072589817`*^9}, {3.986460530300253*^9, 3.986460557665945*^9}, {
  3.9869820811021595`*^9, 
  3.986982093506628*^9}},ExpressionUUID->"10023f65-2f81-4a41-bee0-\
0a97cdaee844"],

Cell[TextData[{
 "Now, the probability to obtain the event ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["a", "1"], ",", "...", ",", 
     SubscriptBox["a", "n"]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "db34a961-e3bf-fa4b-a9c9-142612428a75"],
 " at given ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     RowBox[{"...", 
      SubscriptBox["x", "n"]}]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "53e7dd55-c97a-e449-8534-185ee40de51d"],
 ", i.e., clicks the output pin   ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "1"], TraditionalForm]],ExpressionUUID->
  "e0cef843-2ebc-ea42-8e1a-83b02911dd44"],
 " for 1-th player,...,output pin  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "n"], TraditionalForm]],ExpressionUUID->
  "3de5b9d2-6960-ae42-9fad-53cadfe55edb"],
 " for the n-th player is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", 
    RowBox[{"a", "|", "x"}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d0e1bec0-39d5-4947-ba78-ce8c3ef2304f"],
 ", explicitly,"
}], "Text",
 CellChangeTimes->{{3.8483123972932844`*^9, 3.8483125426470103`*^9}, {
  3.966673063956279*^9, 3.9666730671693573`*^9}, {3.9863580091820793`*^9, 
  3.986358010099285*^9}, {3.9863584801444798`*^9, 3.986358591894308*^9}, {
  3.986358704617977*^9, 3.986358716559849*^9}, {3.986358810485773*^9, 
  3.9863588221637325`*^9}},ExpressionUUID->"94b1e0b6-0a12-43aa-841c-\
294f2c19c8f7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"P", 
    RowBox[{"(", 
     RowBox[{"a", "|", "x"}], ")"}]}], "=", 
   RowBox[{
    RowBox[{"|", 
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{"a", "|", 
       RowBox[{
        SubscriptBox["T\[CapitalPhi]", "x"], "\[Psi]"}]}], 
      "\[RightAngleBracket]"}], 
     SuperscriptBox["|", "2"]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{"\[Psi]", " ", "|", 
        RowBox[{
         RowBox[{
          SubscriptBox["\[CapitalPhi]", "x"], "\[ConjugateTranspose]"}], 
         RowBox[{"T", "\[ConjugateTranspose]"}]}], "|", "a"}], 
       "\[RightAngleBracket]"}], 
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{"a", "|", 
        RowBox[{"T", " ", 
         SubscriptBox["\[CapitalPhi]", "x"]}], "|", "\[Psi]"}], 
       "\[RightAngleBracket]"}]}], "=", 
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{"\[Psi]", "|", 
       SubscriptBox["M", 
        RowBox[{"a", "|", "x"}]], "|", "\[Psi]"}], 
      "\[RightAngleBracket]"}]}]}]}], 
  "\[IndentingNewLine]"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8483118426314697`*^9, 3.8483119133699074`*^9}, {
   3.8483121195034585`*^9, 3.8483122747904587`*^9}, {3.8483123686448994`*^9, 
   3.848312369129283*^9}, {3.8483124924421587`*^9, 3.848312506956495*^9}, {
   3.8483125560684566`*^9, 3.848312737512331*^9}, {3.848312774228589*^9, 
