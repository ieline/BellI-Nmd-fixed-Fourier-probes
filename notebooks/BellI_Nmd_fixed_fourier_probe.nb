   3.9666722590672092`*^9, 3.9666722595144653`*^9}, {3.9666725200533752`*^9, 
   3.9666725207198668`*^9}, {3.966672588231417*^9, 3.966672675136004*^9}, {
   3.9666730713312516`*^9, 3.966673123628471*^9}, {3.986358018861389*^9, 
   3.986358173879772*^9}, {3.986358609603012*^9, 3.986358761998192*^9}, {
   3.9863588241816196`*^9, 3.9863588952403984`*^9}, {3.98635894502787*^9, 
