Cell[TextData[{
 "We compute the characteristic function \[Chi] of the probability, i.e. the \
Fourier transform of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "(", 
    RowBox[{
     SubscriptBox["a", "1"], ",", 
     RowBox[{"...", "|", 
      RowBox[{
       SubscriptBox["s", "1"], "..."}]}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"3dc4988a-c579-4f4b-abe4-6734ebdf31d0"]
}], "Text",
 CellChangeTimes->{{3.848313325421427*^9, 3.8483133329766045`*^9}, {
  3.9475774151300783`*^9, 3.9475775099464445`*^9}, {3.966672744810486*^9, 
  3.966672808164322*^9}, {3.966673156407673*^9, 3.966673172056892*^9}, {
  3.966673424540803*^9, 
  3.9666734343810844`*^9}},ExpressionUUID->"4f43fb9e-b44e-4da1-95f3-\
9fbb96628bae"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["\[Chi]", 
    RowBox[{"\[CapitalOmega]", "|", "X"}]], 
   RowBox[{"(", 
    RowBox[{"\[Omega]", "|", "x"}], ")"}]}], "=", 
  RowBox[{
   RowBox[{
    UnderscriptBox["\[Sum]", "a"], 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", 
       FractionBox[
        RowBox[{"2", "\[Pi]"}], "d"], 
       RowBox[{"a", "\[CenterDot]", "\[Omega]"}]}]], "P", 
     RowBox[{"(", 
      RowBox[{"a", "|", "x"}], ")"}]}]}], "=", 
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{"\[Psi]", "|", 
      RowBox[{
       UnderscriptBox["\[Sum]", "a"], 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", 
          FractionBox[
           RowBox[{"2", "\[Pi]"}], "d"], 
          RowBox[{"a", "\[CenterDot]", "\[Omega]"}]}]], 
        SubscriptBox["M", 
         RowBox[{"a", "|", "x"}]]}]}], "|", "\[Psi]"}], 
     "\[RightAngleBracket]"}], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SuperscriptBox[
       SubscriptBox["\[TensorProduct]", 
        RowBox[{"k", "=", "1"}]], "n"], 
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{
         SubscriptBox["a", "k"], "=", "1"}], "d"], 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", 
          FractionBox[
           RowBox[{"2", "\[Pi]"}], "d"], 
          SubscriptBox["a", "k"], 
          SubscriptBox["\[Omega]", "k"]}]], 
        SubscriptBox["M", 
         RowBox[{
          SubscriptBox["a", "k"], "|", 
          SubscriptBox["x", "k"]}]], 
        TemplateBox[{"\[Psi]"},
         "Ket"]}]}]}], "=", 
     RowBox[{"Tr\[Rho]", " ", "B"}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8483118426314697`*^9, 3.8483119133699074`*^9}, {
  3.8483121195034585`*^9, 3.8483122747904587`*^9}, {3.8483123686448994`*^9, 
  3.848312369129283*^9}, {3.8483124924421587`*^9, 3.848312506956495*^9}, {
  3.8483125560684566`*^9, 3.848312737512331*^9}, {3.848312774228589*^9, 
  3.8483128698398514`*^9}, {3.848312904956608*^9, 3.8483130986832085`*^9}, {
