   3.986359063466234*^9, 3.986359071277607*^9}, {3.9863591105048733`*^9, 
   3.9863592210030384`*^9}, 3.986359390116068*^9, {3.9863594577513695`*^9, 
   3.986359531426506*^9}, {3.9863595650676823`*^9, 3.9863595732703686`*^9}, {
   3.9864601266569977`*^9, 3.986460144260048*^9}, {3.9869821740894547`*^9, 
   3.9869821759128895`*^9}},ExpressionUUID->"f032e74c-b0db-4265-b006-\
293e353e12c9"],

Cell["Now, we notice that ", "Text",
 CellChangeTimes->{{3.8483131082806587`*^9, 3.8483133198833513`*^9}, {
  3.8483136054915257`*^9, 3.848313614342288*^9}, {3.8483136563330193`*^9, 
  3.8483137252103124`*^9}, {3.966673138723549*^9, 3.966673147057007*^9}, {
  3.986359603696804*^9, 
  3.9863596938292427`*^9}},ExpressionUUID->"a966809e-1bb9-bd48-a815-\
9ee3c839df47"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     FormBox[
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["M", 
          RowBox[{"a", "|", "x"}]], "=", 
         RowBox[{
          RowBox[{
           RowBox[{
            SubscriptBox["\[CapitalPhi]", "x"], "\[ConjugateTranspose]"}], 
           RowBox[{"T", "\[ConjugateTranspose]"}]}], "|", "a"}]}], 
        "\[RightAngleBracket]"}], 
       RowBox[{"\[LeftAngleBracket]", 
        RowBox[{"a", "|", 
         RowBox[{"T", " ", 
          SubscriptBox["\[CapitalPhi]", "x"]}]}]}]}],
      TraditionalForm], "=", 
     RowBox[{"|", 
      RowBox[{
       RowBox[{
        SubscriptBox["\[CapitalPhi]", 
         SubscriptBox["x", "1"]], "\[ConjugateTranspose]"}], 
       RowBox[{"T", "\[ConjugateTranspose]"}], "  ", 
       SubscriptBox["a", "1"]}]}]}], ",", "...", ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalPhi]", 
       SubscriptBox["x", "n"]], "\[ConjugateTranspose]"}], 
     RowBox[{"T", "\[ConjugateTranspose]"}], " ", 
     SubscriptBox["a", "n"]}]}], "\[RightAngleBracket]"}], 
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    RowBox[{
     SubscriptBox["a", "1"], "T", " ", 
     SubscriptBox["\[CapitalPhi]", 
      SubscriptBox["x", "1"]]}], ",", "...", ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["a", "n"], "T", " ", 
      SubscriptBox["\[CapitalPhi]", 
       SubscriptBox["x", "n"]]}], "|", 
     "\[IndentingNewLine]"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8483118426314697`*^9, 3.8483119133699074`*^9}, {
   3.8483121195034585`*^9, 3.8483122747904587`*^9}, {3.8483123686448994`*^9, 
   3.848312369129283*^9}, {3.8483124924421587`*^9, 3.848312506956495*^9}, {
   3.8483125560684566`*^9, 3.848312737512331*^9}, {3.848312774228589*^9, 
