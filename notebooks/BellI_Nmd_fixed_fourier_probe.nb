Cell[CellGroupData[{

Cell["(3,2,2)", "Subsection",
 CellChangeTimes->{{3.848315425874284*^9, 3.848315428287324*^9}, {
  3.848320321296503*^9, 
  3.848320321359335*^9}},ExpressionUUID->"1d9819bf-ea63-4cc8-a016-\
2853610eea6b"],

Cell["\<\
Should be interesting to check if such a Bell inequality detect W state.\
\>", "Text",
 CellChangeTimes->{{3.848320325022994*^9, 
  3.848320346078151*^9}},ExpressionUUID->"7a734957-b025-4d55-8c33-\
b880d15281ae"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"W", "[", "n_", "]"}], ":=", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["n"]], 
   RowBox[{"Flatten", "[", 
    RowBox[{"Total", "[", 
     RowBox[{"(", 
      RowBox[{"KroneckerProduct", "@@@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"i", "\[Equal]", " ", "j"}], ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", "0"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "1"}], "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "n"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "n"}], "}"}]}], "]"}]}], ")"}], "]"}], 
    "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"o", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0"}], "}"}]}], ";", 
  RowBox[{"i", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "1"}], "}"}]}], ";", 
  RowBox[{"W2", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{
      SqrtBox[
       RowBox[{"1", "-", 
        RowBox[{
         UnderoverscriptBox["\[Sum]", 
          RowBox[{"i", "=", "1"}], "3"], 
         SubscriptBox["x", "i"]}]}]], 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{"o", ",", "o", ",", "o"}], "]"}]}], "+", 
     RowBox[{
      SqrtBox[
       SubscriptBox["x", "1"]], 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{"i", ",", "o", ",", "o"}], "]"}]}], "+", 
     RowBox[{
      SqrtBox[
       SubscriptBox["x", "2"]], 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{"o", ",", "i", ",", "o"}], "]"}]}], "+", 
     RowBox[{
      SqrtBox[
       SubscriptBox["x", "3"]], 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{"o", ",", "o", ",", "i"}], "]"}]}]}], "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.8483191136109524`*^9, 3.848319115858671*^9}, {
  3.84831914650323*^9, 3.84831914866755*^9}, {3.8483195286795626`*^9, 
  3.848319530164095*^9}, {3.8483195928021097`*^9, 3.848319593302108*^9}, {
