Cell[TextData[{
 "T\[CapitalPhi]c is dxd, F is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["d", "2"], 
    SuperscriptBox["xd", "2"]}], TraditionalForm]],ExpressionUUID->
  "cf11becf-08a9-4c75-90f0-4e8bc3d1d430"],
 " B=Kronecker[F,...,F] n times"
}], "Text",
 CellChangeTimes->{{3.851574015263111*^9, 3.851574031683461*^9}, {
  3.8515741215988073`*^9, 
  3.8515741391376247`*^9}},ExpressionUUID->"b73c0c1a-be5e-404c-8e9d-\
a3c44c6f4b7f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"quantum", " ", "bound", " ", "\[CapitalGamma]"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Phi]", "[", 
     RowBox[{"n_", ",", "m_", ",", "d_"}], "]"}], ":=", 
    RowBox[{"Array", "[", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CurlyPhi]", 
        RowBox[{"#1", ",", "#2", ",", "#3"}]], "&"}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "m", ",", "d"}], "}"}]}], "]"}]}], " ", 
   RowBox[{"(*", 
    RowBox[{"all", " ", "possible", " ", "phase", " ", "of", " ", "the", " ", 
     RowBox[{"(", 
      RowBox[{"n", ",", "m", ",", "d"}], ")"}], " ", "Belle", " ", 
     "scenario"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"\[Mu]", "=", 
     RowBox[{
      RowBox[{"\[CapitalPhi]", "\[ConjugateTranspose]"}], 
      RowBox[{"T", "\[ConjugateTranspose]"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Mu]", "[", 
     RowBox[{
     "n_Integer", ",", "m_Integer", ",", "d_Integer", ",", "k_Integer", ",", 
      "x_Integer"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"DiagonalMatrix", "[", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "\[ImaginaryI]"}], " ", 
         RowBox[{
          RowBox[{"\[Phi]", "[", 
           RowBox[{"n", ",", "m", ",", "d"}], "]"}], "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "x", ",", "All"}], "]"}], "]"}]}]], "]"}], ".", 
      RowBox[{"(", 
       RowBox[{
        FractionBox["1", 
         SqrtBox["d"]], 
        RowBox[{"Array", "[", 
         RowBox[{
          RowBox[{
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"\[ImaginaryI]", " ", 
             FractionBox[
              RowBox[{"2", "\[Pi]"}], "d"], 
             RowBox[{"(", 
              RowBox[{"#2", "-", "1"}], ")"}], 
             RowBox[{"(", 
              RowBox[{"#1", "-", "1"}], ")"}]}]], "&"}], ",", 
          RowBox[{"{", 
           RowBox[{"d", ",", "d"}], "}"}]}], "]"}]}], ")"}]}], "/;", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"k", "<=", "n"}], "&&", 
       RowBox[{"x", "<=", "m"}]}], ")"}]}]}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"\[Mu]c", "=", 
     RowBox[{"T", " ", "\[CapitalPhi]"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"T\[CapitalPhi]c", "[", 
     RowBox[{
     "n_Integer", ",", "m_Integer", ",", "d_Integer", ",", "k_Integer", ",", 
      "x_Integer"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       SqrtBox["d"]], 
      RowBox[{
       RowBox[{"Array", "[", 
        RowBox[{
         RowBox[{
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{
